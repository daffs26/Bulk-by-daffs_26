{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/components/*": [
        "./shared/components/*"
      ],
      "@/hooks/*": [
        "./shared/hooks/*"
      ],
      "@/constants/*": [
        "./shared/constants/*"
      ],
      "@/config/*": [
        "./shared/config/*"
      ],
      "@/web/*": [
        "./web/*"
      ],
      "@/*": [
        "./*"
      ],
      "@/assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}